# Path to the SQLite checkpointer database used by LangGraph.
PHARMAIDE_CHECKPOINT_DB_PATH=./pharmaide.db

# When true, mounts POST /debug/graph for end-to-end seam checks.
# Must remain false outside local dev.
PHARMAIDE_DEBUG_ROUTES_ENABLED=false

# "console" for colored dev output, "json" for prod-shaped structured logs.
PHARMAIDE_LOG_MODE=console
